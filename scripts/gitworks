#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
GITLAB_OPS="${GITLAB_OPS:-$HOME/.codex/skills/gitlab-workflow/scripts/gitlab_ops.py}"
GLAB="${GLAB:-$(command -v glab || true)}"

remote_url() {
  git -C "$REPO_ROOT" remote get-url "${GIT_REMOTE:-origin}" 2>/dev/null || true
}

derive_gitlab_host() {
  local url="$1"
  if [[ "$url" =~ ^https?://([^/@]+@)?([^/:]+(:[0-9]+)?)/ ]]; then
    printf '%s\n' "${BASH_REMATCH[2]}"
    return
  fi
  if [[ "$url" =~ ^ssh://([^/@]+@)?([^/:]+(:[0-9]+)?)/ ]]; then
    printf '%s\n' "${BASH_REMATCH[2]}"
    return
  fi
  if [[ "$url" =~ ^[^@]+@([^:]+): ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
  fi
}

derive_project_path() {
  local url="$1"
  local path=""
  if [[ "$url" =~ ^https?://([^/@]+@)?[^/]+/(.+)$ ]]; then
    path="${BASH_REMATCH[2]}"
  elif [[ "$url" =~ ^ssh://([^/@]+@)?[^/]+/(.+)$ ]]; then
    path="${BASH_REMATCH[2]}"
  elif [[ "$url" =~ ^[^@]+@[^:]+:(.+)$ ]]; then
    path="${BASH_REMATCH[1]}"
  fi
  path="${path%.git}"
  printf '%s\n' "$path"
}

REMOTE_URL="$(remote_url)"
PROJECT_PATH="${GITLAB_PROJECT_PATH:-$(derive_project_path "$REMOTE_URL")}"
GITLAB_HOST="${GITLAB_HOST:-$(derive_gitlab_host "$REMOTE_URL")}"

if [[ -z "$GLAB" && -x "$HOME/go/bin/glab" ]]; then
  GLAB="$HOME/go/bin/glab"
fi

usage() {
  cat <<'EOF'
Usage:
  scripts/gitworks status
  scripts/gitworks workflow <base-branch> <work-branch> <commit-message>
  scripts/gitworks mr-list
  scripts/gitworks mr-create <target-branch> <title> [description]
  scripts/gitworks ci-list
  scripts/gitworks ci-run [branch]
  scripts/gitworks ci-status

Environment:
  GITLAB_PROJECT_PATH  Override GitLab project path.
  GITLAB_HOST          Override GitLab host used by glab auth status.
  GIT_REMOTE           Override git remote used for auto-detection. Default: origin.
  GITLAB_OPS          Override gitlab_ops.py path.
  GLAB                Override glab binary path.
EOF
}

need_glab() {
  if [[ -z "$GLAB" || ! -x "$GLAB" ]]; then
    echo "glab is not installed or not executable. Install it, or set GLAB=/path/to/glab." >&2
    exit 1
  fi
}

cmd="${1:-}"
case "$cmd" in
  status)
    git -C "$REPO_ROOT" status --short --branch
    need_glab
    if [[ -n "$GITLAB_HOST" ]]; then
      "$GLAB" auth status --hostname "$GITLAB_HOST"
    else
      "$GLAB" auth status
    fi
    ;;
  workflow)
    if [[ $# -lt 4 ]]; then
      usage >&2
      exit 1
    fi
    python3 "$GITLAB_OPS" workflow \
      --repo "$REPO_ROOT" \
      --base-branch "$2" \
      --branch "$3" \
      --message "$4" \
      --rebase
    ;;
  mr-list)
    need_glab
    if [[ -z "$PROJECT_PATH" ]]; then
      echo "Cannot determine GitLab project path. Set GITLAB_PROJECT_PATH=<group>/<project>." >&2
      exit 1
    fi
    "$GLAB" mr list --repo "$PROJECT_PATH"
    ;;
  mr-create)
    if [[ $# -lt 3 ]]; then
      usage >&2
      exit 1
    fi
    need_glab
    if [[ -z "$PROJECT_PATH" ]]; then
      echo "Cannot determine GitLab project path. Set GITLAB_PROJECT_PATH=<group>/<project>." >&2
      exit 1
    fi
    target="$2"
    title="$3"
    description="${4:-}"
    "$GLAB" mr create \
      --repo "$PROJECT_PATH" \
      --target-branch "$target" \
      --title "$title" \
      --description "$description" \
      --remove-source-branch \
      --yes
    ;;
  ci-list)
    need_glab
    if [[ -z "$PROJECT_PATH" ]]; then
      echo "Cannot determine GitLab project path. Set GITLAB_PROJECT_PATH=<group>/<project>." >&2
      exit 1
    fi
    "$GLAB" ci list --repo "$PROJECT_PATH"
    ;;
  ci-run)
    need_glab
    if [[ -z "$PROJECT_PATH" ]]; then
      echo "Cannot determine GitLab project path. Set GITLAB_PROJECT_PATH=<group>/<project>." >&2
      exit 1
    fi
    if [[ $# -ge 2 ]]; then
      "$GLAB" ci run --repo "$PROJECT_PATH" --branch "$2"
    else
      "$GLAB" ci run --repo "$PROJECT_PATH"
    fi
    ;;
  ci-status)
    need_glab
    if [[ -z "$PROJECT_PATH" ]]; then
      echo "Cannot determine GitLab project path. Set GITLAB_PROJECT_PATH=<group>/<project>." >&2
      exit 1
    fi
    "$GLAB" ci status --repo "$PROJECT_PATH"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
