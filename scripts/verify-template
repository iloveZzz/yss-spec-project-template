#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

matt_skill_names=(
  "ask-matt"
  "grill-with-docs"
  "to-prd"
  "to-issues"
  "implement"
  "tdd"
  "diagnosing-bugs"
  "code-review"
  "domain-modeling"
  "codebase-design"
  "improve-codebase-architecture"
  "triage"
  "prototype"
  "research"
  "setup-matt-pocock-skills"
  "resolving-merge-conflicts"
)

additional_skill_names=(
  "competitive-intelligence"
)

matt_skill_roots=(
  ".agents/skills"
  ".claude/skills"
  ".codex/skills"
  ".hermes/skills"
  ".pi/skills"
  ".trae/skills"
)

removed_flow_paths=(
  "docs/superpowers"
  "openspec"
  ".claude/commands/opsx"
  ".pi/prompts"
)

removed_skill_names=(
  "openspec-apply-change"
  "openspec-archive-change"
  "openspec-bulk-archive-change"
  "openspec-continue-change"
  "openspec-explore"
  "openspec-ff-change"
  "openspec-new-change"
  "openspec-onboard"
  "openspec-propose"
  "openspec-sync-specs"
  "openspec-verify-change"
  "using-superpowers"
  "brainstorming"
  "writing-plans"
  "executing-plans"
  "test-driven-development"
  "requesting-code-review"
  "receiving-code-review"
  "verification-before-completion"
  "systematic-debugging"
)

legacy_text_paths=(
  "AGENTS.md"
  ".codex/skills/yss-product-lifecycle/SKILL.md"
  "docs/process/harness-work-unit-map.md"
  "docs/process/lifecycle-artifact-map.md"
  "docs/process/harness-process-tailoring.md"
  "docs/agents/skills-maintenance.md"
  "docs/user-guide/product-lifecycle-workflow.md"
  "docs/user-guide/lifecycle-best-practices.md"
  "docs/user-guide/product-rd-lifecycle-best-practices.md"
  "docs/templates/implementation-routing-template.md"
  "docs/templates/spec-delta-template.md"
)

legacy_text_patterns=(
  "active change"
  "openspec/changes"
  "openspec list"
  "test-driven-development"
  "requesting-code-review"
  "receiving-code-review"
  "verification-before-completion"
)

required_template_files=(
  "docs/templates/spec-delta-template.md"
)

for root in "${matt_skill_roots[@]}"; do
  for skill in "${matt_skill_names[@]}"; do
    path="$root/$skill/SKILL.md"
    test -f "$path" || {
      echo "missing Matt skill: $path" >&2
      exit 1
    }
  done
  for skill in "${additional_skill_names[@]}"; do
    path="$root/$skill/SKILL.md"
    test -f "$path" || {
      echo "missing additional skill: $path" >&2
      exit 1
    }
  done
done

for path in "${removed_flow_paths[@]}"; do
  test ! -e "$path" || {
    echo "removed flow path still exists: $path" >&2
    exit 1
  }
done

for root in "${matt_skill_roots[@]}"; do
  for skill in "${removed_skill_names[@]}"; do
    path="$root/$skill"
    test ! -e "$path" || {
      echo "removed legacy skill still exists: $path" >&2
      exit 1
    }
  done
done

for path in "${legacy_text_paths[@]}"; do
  test -f "$path" || {
    echo "legacy text check target missing: $path" >&2
    exit 1
  }
  for pattern in "${legacy_text_patterns[@]}"; do
    hits="$(grep -F -n "$pattern" "$path" || true)"
    if [ -n "$hits" ]; then
      echo "legacy flow text found in $path: $pattern" >&2
      echo "$hits" >&2
      exit 1
    fi
  done
done

for path in "${required_template_files[@]}"; do
  test -f "$path" || {
    echo "missing required template: $path" >&2
    exit 1
  }
done

git diff --check

ruby <<'RUBY'
require "yaml"
require "pathname"

root = Pathname.pwd

["docs/templates/openapi-spec-template.yaml"].each do |path|
  text = File.read(root.join(path))
  text = text.sub(/\A---\n.*?\n---\n/m, "")
  YAML.safe_load(text, permitted_classes: [], aliases: true)
end

markdown_paths = Dir.glob("*.md") + Dir.glob("docs/**/*.md")

missing = []
markdown_paths.uniq.sort.each do |path|
  text = File.read(path)
  text.scan(/\[[^\]]+\]\(([^)]+)\)/).flatten.each do |target|
    next if target.start_with?("http://", "https://", "mailto:", "#")
    clean = target.split("#", 2).first
    next if clean.empty?
    resolved = Pathname.new(path).dirname.join(clean).cleanpath
    missing << "#{path} -> #{target}" unless root.join(resolved).exist?
  end
end

unless missing.empty?
  warn "broken markdown links:"
  missing.each { |item| warn "  #{item}" }
  exit 1
end
RUBY

echo "template verification passed"
