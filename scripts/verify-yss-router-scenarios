  actual = execution_violations(CONTRACT, result, *valid_args)
  failures << "Execution mutation did not block: #{expected}" unless actual.include?(blocker)
end

controlled_required = CONTRACT.dig("tdd_modes", "controlled-generation", "required")
controlled_complete = controlled_required.to_h { |field| [field, field == "generator_inputs" || field == "expected_files" || field == "verification_commands" ? ["value"] : "value"] }
def controlled_generation_violations(required, mode, details)
  return [] unless mode == "controlled-generation"

  required.reject do |field|
    value = details[field]
    value.is_a?(Array) ? !value.empty? : !value.to_s.empty?
  end
end

unless controlled_generation_violations(controlled_required, "controlled-generation", controlled_complete).empty?
  failures << "Complete controlled-generation details were rejected"
end
controlled_required.each do |field|
  mutation = controlled_complete.reject { |key, _| key == field }
  unless controlled_generation_violations(controlled_required, "controlled-generation", mutation).include?(field)
    failures << "controlled-generation did not require #{field}"
  end
end
failures << "behavior-tdd incorrectly required generation details" unless controlled_generation_violations(controlled_required, "behavior-tdd", {}).empty?

versioning = CONTRACT.fetch("contract_versioning")
unless versioning["full_reroute_current_status"] == "stale" && versioning["next_version"] == "increment" &&
       versioning["affected_work_units_status"] == "paused" &&
       versioning["required_history"] == %w[previous_contract_ref stale_reason reroute_trigger]
  failures << "Full reroute versioning contract invalid"
end

def full_reroute(contract, current_contract, trigger)
  destination = contract.fetch("reroute_destinations")[trigger]
  return nil unless destination

  {
    "current_status" => contract.dig("contract_versioning", "full_reroute_current_status"),
    "next_version" => current_contract.fetch("contract_version") + 1,
    "history" => {
      "previous_contract_ref" => current_contract.fetch("contract_ref"),
      "stale_reason" => "new-impact",
      "reroute_trigger" => trigger
    },
    "affected_work_units_status" => contract.dig("contract_versioning", "affected_work_units_status"),
    "destination" => destination
  }
end

current_contract = {"contract_ref" => "docs/contracts/order-create-v2.yaml", "contract_version" => 2}
CONTRACT.fetch("full_reroute_triggers").each do |trigger|
  destination = CONTRACT.fetch("reroute_destinations")[trigger]
  transition = full_reroute(CONTRACT, current_contract, trigger)
  unless transition && transition["current_status"] == "stale" && transition["next_version"] == 3 &&
         transition["affected_work_units_status"] == "paused" && transition["destination"] == destination &&
         CONTRACT.dig("contract_versioning", "required_history").all? { |field| !transition.dig("history", field).to_s.empty? }
    failures << "Full reroute transition failed: #{trigger}"
  end
end
failures << "API/database schema reroutes collapsed" if CONTRACT.dig("reroute_destinations", "api-schema-impact") == CONTRACT.dig("reroute_destinations", "database-schema-impact")
failures << "Unknown reroute trigger did not stop" unless full_reroute(CONTRACT, current_contract, "unknown").nil?

