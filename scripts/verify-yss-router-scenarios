def tdd_mode(contract, impact)
  contract.fetch("tdd_modes").each do |mode, definition|
    return mode if definition.fetch("impacts").include?(impact)
  end
  nil
end

%w[domain-rule state-machine transaction permission page-interaction].each do |impact|
  failures << "#{impact} must use behavior-tdd" unless tdd_mode(CONTRACT, impact) == "behavior-tdd"
end
%w[project-scaffold dto-boilerplate mapstruct-generated frozen-openapi-client].each do |impact|
  failures << "#{impact} must use controlled-generation" unless tdd_mode(CONTRACT, impact) == "controlled-generation"
end
failures << "Unknown impact must not receive a TDD exception" unless tdd_mode(CONTRACT, "unknown").nil?

def path_within_contract?(path, allowed_paths)
  clean = Pathname.new(path).cleanpath.to_s
  return false if clean != path || Pathname.new(clean).absolute? || clean.start_with?("../")

  allowed_paths.any? do |allowed|
    base = Pathname.new(allowed).cleanpath.to_s.sub(%r{/$}, "")
    clean == base || clean.start_with?(base + "/")
  end
end

def execution_violations(contract, result, allowed_paths, expected_evidence, expected_contract, expected_identity, expected_commands, expected_constraints, existing_files)
  violations = []
  unless result["schema_version"] == 1 && %w[skill slice_id work_unit_id].all? { |field| !result[field].to_s.empty? }
    violations << "violation"
  end
  violations << "violation" unless expected_identity.all? { |field, value| result[field] == value }
  violations << "violation" unless contract.fetch("execution_result_allowed_statuses").include?(result["status"])
  contract.fetch("execution_result_required").each do |field|
    violations << "missing-evidence" unless result.key?(field)
  end
  consumed = result.fetch("consumed_contract", {})
  unless consumed["contract_ref"] == expected_contract["contract_ref"] &&
         consumed["contract_id"] == expected_contract["contract_id"] &&
         consumed["contract_version"] == expected_contract["contract_version"]
    violations << "violation"
  end
  result.fetch("changed_files", []).each do |item|
    path = item.is_a?(Hash) ? item["path"] : item
    valid_item = item.is_a?(Hash) && %w[common frontend backend contract cross_repo].include?(item["contract_area"])
    within_both = path && allowed_paths.all? { |scope_paths| path_within_contract?(path, scope_paths) }
    violations << "path-outside-contract" unless valid_item && within_both
  end
  evidence_paths = result.fetch("evidence_files", []).each_with_object([]) do |item, paths|
    next unless item.is_a?(Hash) && %w[code test generated review verification].include?(item["evidence_type"]) &&
                !item["behavior_ref"].to_s.empty?
    paths << item["path"]
  end
  missing = expected_evidence - evidence_paths
  missing += evidence_paths.reject { |path| existing_files.include?(path) }
  violations << "missing-evidence" unless missing.empty?
  verification_results = result.fetch("verification_results", [])
  verified = !verification_results.empty? && verification_results.all? do |item|
    valid_time = begin
      Time.iso8601(item["executed_at"].to_s)
      true
    rescue ArgumentError
      false
    end
    !item["command"].to_s.empty? && item["result"] == "passed" && valid_time
  end
  violations << "verification-not-executed" unless verified
  actual_commands = verification_results.map { |item| item["command"] }
  violations << "verification-command-mismatch" unless actual_commands.sort == expected_commands.sort
  constraint_results = result.fetch("constraint_results", [])
  result_constraints = constraint_results.map { |item| item["constraint"] }
  violations << "constraint-failed" unless (expected_constraints - result_constraints).empty?
  constraint_results.each do |constraint|
    violations << "constraint-failed" if constraint["status"] == "failed"
    unless %w[passed failed not-applicable].include?(constraint["status"]) && !constraint["constraint"].to_s.empty? &&
           !constraint["evidence_ref"].to_s.empty?
      violations << "violation"
    end
  end
  result.fetch("seam_deferred", []).each do |seam|
    required = contract.fetch("seam_deferred_required")
    violations << "seam-deferred-without-owner" unless required.all? { |field| !seam[field].to_s.empty? }
  end
  violations << "seam-deferred-without-owner" if result["status"] == "seam-deferred" && result.fetch("seam_deferred", []).empty?
  violations << "violation" if result["status"] == "implemented" && !result.fetch("seam_deferred", []).empty?
  violations << "violation" if result["status"] == "not-applicable" && result["not_applicable_reason"].to_s.empty?
  result.fetch("deviations", []).each do |deviation|
    required = contract.fetch("deviation_required")
    violations << "unapproved-deviation" unless required.all? { |field| !deviation[field].to_s.empty? }
  end
  violations << "new-impacts" unless result.fetch("new_impacts", []).empty?
  violations << result["status"] if %w[drift violation].include?(result["status"])
  violations & contract.fetch("execution_blockers")
end

expected_contract = {"contract_ref" => "docs/contracts/order-create-v2.yaml", "contract_id" => "order-create", "contract_version" => 2}
expected_identity = {"skill" => "yss-domain", "slice_id" => "order-create", "work_unit_id" => "create-order"}
