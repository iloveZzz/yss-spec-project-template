#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"
require "json"
require "pathname"

ROOT = Pathname.new(__dir__).join("..").realpath
LOCK_PATH = ROOT.join("skills-lock.json")
SHARED_ROOT = ROOT.join(".agents/skills")
PROJECTION_ROOTS = %w[
  .claude/skills
  .codex/skills
  .hermes/skills
  .pi/skills
  .trae/skills
].freeze
GIT_WORKTREE = system(
  "git",
  "rev-parse",
  "--is-inside-work-tree",
  out: File::NULL,
  err: File::NULL
)

def tracked_skill_names(relative_root)
  return [] unless GIT_WORKTREE

  IO.popen(
    ["git", "ls-files", "-z", "--", relative_root],
    err: File::NULL,
    &:read
  ).split("\0").map { |item| item.split("/")[2] }.compact.uniq
end

def skill_names(root)
  return [] unless root.directory?

  root.children.select(&:directory?).map { |item| item.basename.to_s }.sort
end

def tree_hash(root)
  digest = Digest::SHA256.new
  root.glob("**/*", File::FNM_DOTMATCH)
      .reject { |item| item.directory? || item.basename.to_s == ".DS_Store" }
      .sort_by { |item| item.relative_path_from(root).to_s }
      .each do |item|
    relative = item.relative_path_from(root).to_s
    digest << relative << "\0" << item.binread << "\0"
  end
  digest.hexdigest
end

def old_metadata
  return {} unless LOCK_PATH.file?

  parsed = JSON.parse(LOCK_PATH.read)
  skills = parsed.fetch("skills", {})
  return skills unless skills.key?("shared") || skills.key?("platform")

  shared = skills.fetch("shared", {})
  platform = skills.fetch("platform", {}).values.reduce({}) { |all, group| all.merge(group) }
  shared.merge(platform)
rescue JSON::ParserError
  {}
end

def existing_shared_names
  return nil unless LOCK_PATH.file?

  parsed = JSON.parse(LOCK_PATH.read)
  shared = parsed.dig("skills", "shared")
  return shared.keys.sort if parsed["version"] == 3 && shared.is_a?(Hash)

  nil
rescue JSON::ParserError
  nil
end

def existing_platform_inventory
  return nil unless LOCK_PATH.file?

  parsed = JSON.parse(LOCK_PATH.read)
  platform = parsed.dig("skills", "platform")
  return nil unless parsed["version"] == 3 && platform.is_a?(Hash)

  platform.transform_values { |skills| skills.keys.sort }
rescue JSON::ParserError
  nil
end

def metadata_for(skill_name, skill_path, target_root, previous)
  old = previous.fetch(skill_name, {})
  metadata = {
    "source" => old.fetch("source", "project"),
    "sourceType" => old.fetch("sourceType", "local"),
    "skillPath" => old.fetch("skillPath", skill_path),
    "effectiveHash" => tree_hash(target_root)
  }
  upstream_hash = old["upstreamHash"] || old["computedHash"]
  metadata["upstreamHash"] = upstream_hash if upstream_hash
  metadata
end

previous = old_metadata
add_names = ARGV.grep(/\A--add=/).map { |item| item.split("=", 2).last }
remove_names = ARGV.grep(/\A--remove=/).map { |item| item.split("=", 2).last }
platform_additions = ARGV.grep(/\A--add-platform=/).map do |item|
  item.split("=", 2).last.split(":", 2)
end
shared_names = existing_shared_names || skill_names(SHARED_ROOT)
shared_names = ((shared_names + add_names).uniq - remove_names).sort

missing_shared = shared_names.reject { |skill_name| SHARED_ROOT.join(skill_name).directory? }
unless missing_shared.empty?
  warn "锁文件声明的共享 skills 缺少权威内容: #{missing_shared.join(', ')}"
  exit 1
end

tracked_shared_names = tracked_skill_names(".agents/skills")
obsolete_names = %w[to-prd to-issues]
unlocked_tracked = tracked_shared_names - shared_names - obsolete_names
unless unlocked_tracked.empty?
  warn "发现未登记到 skills-lock.json 的已跟踪共享 skills: #{unlocked_tracked.sort.join(', ')}"
  warn "确认新增后运行 scripts/update-skill-lock --add=<skill-name>"
  exit 1
end

all_targets = [".agents/skills", *PROJECTION_ROOTS]

shared = shared_names.to_h do |skill_name|
  skill_root = SHARED_ROOT.join(skill_name)
  metadata = metadata_for(
    skill_name,
    ".agents/skills/#{skill_name}/SKILL.md",
    skill_root,
    previous
  )
  metadata["targets"] = all_targets
  [skill_name, metadata]
end

existing_platform = existing_platform_inventory
platform = {}
PROJECTION_ROOTS.each do |relative_root|
  target_root = ROOT.join(relative_root)
  default_names = skill_names(target_root) - shared_names
  platform_names = existing_platform ? existing_platform.fetch(relative_root, []) : default_names
  additions = platform_additions.select { |root_name, _| root_name == relative_root }.map(&:last)
  platform_names = ((platform_names + additions).uniq - remove_names - shared_names).sort

  missing_platform = platform_names.reject { |skill_name| target_root.join(skill_name).directory? }
  unless missing_platform.empty?
    warn "锁文件声明的平台 skills 缺少内容 (#{relative_root}): #{missing_platform.join(', ')}"
    exit 1
  end

  tracked_platform_names = tracked_skill_names(relative_root)
  unlocked_platform = tracked_platform_names - shared_names - platform_names - obsolete_names
  unless unlocked_platform.empty?
    warn "发现未登记的平台 skills (#{relative_root}): #{unlocked_platform.sort.join(', ')}"
    warn "确认新增后运行 scripts/update-skill-lock --add-platform=#{relative_root}:<skill-name>"
    exit 1
  end

  next if platform_names.empty?

  platform[relative_root] = platform_names.to_h do |skill_name|
    skill_root = target_root.join(skill_name)
    metadata = metadata_for(
      skill_name,
      "#{relative_root}/#{skill_name}/SKILL.md",
      skill_root,
      previous
    )
    metadata["targets"] = [relative_root]
    [skill_name, metadata]
  end
end

manifest = {
  "version" => 3,
  "generatedBy" => "scripts/update-skill-lock",
  "canonicalRoot" => ".agents/skills",
  "projectionRoots" => PROJECTION_ROOTS,
  "skills" => {
    "shared" => shared,
    "platform" => platform
  }
}
rendered = JSON.pretty_generate(manifest) + "\n"

if ARGV.include?("--check")
  unless LOCK_PATH.file? && LOCK_PATH.read == rendered
    warn "skills-lock.json is stale; run scripts/update-skill-lock"
    exit 1
  end
  puts "skills-lock.json matches distributed skills"
else
  LOCK_PATH.write(rendered)
  puts "updated skills-lock.json with #{shared.length} shared skills and #{platform.values.sum(&:length)} platform skills"
end
